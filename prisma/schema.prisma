// SaaSPilot — curated SaaS link directory
// Phases & sub-phases form the navigation taxonomy.
// Resources are the external links, classified into sub-phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ContentType {
  Article
  Guide
  Checklist
  Template
  Framework
  CaseStudy
  Course
  Video
  Resource
  ToolCollection
}

enum Difficulty {
  Beginner
  Intermediate
  Advanced
}

enum ResourceStatus {
  draft
  published
}

model Phase {
  id          String   @id // e.g. "discover"
  number      String // "01"
  title       String
  shortTitle  String
  eyebrow     String
  goal        String
  description String
  outcome     String
  accent      String
  position    Int

  subPhases       SubPhase[]
  primaryResources Resource[] @relation("PrimaryPhase")

  @@map("phases")
}

model SubPhase {
  id          String   @id // e.g. "problem-discovery" (globally unique)
  phaseId     String
  title       String
  description String
  topics      String[] @default([])
  position    Int

  phase     Phase      @relation(fields: [phaseId], references: [id], onDelete: Cascade)
  resources Resource[] @relation("ResourceSubPhases")

  @@index([phaseId])
  @@map("sub_phases")
}

model Resource {
  id               String         @id @default(cuid())
  slug             String         @unique
  title            String
  description      String
  url              String // external destination link
  sourceDomain     String? // e.g. "stripe.com"
  type             ContentType
  difficulty       Difficulty
  estimatedMinutes Int            @default(10)
  featured         Boolean        @default(false)
  status           ResourceStatus @default(published)
  tags             String[]       @default([])

  primaryPhaseId String
  primaryPhase   Phase  @relation("PrimaryPhase", fields: [primaryPhaseId], references: [id])

  subPhases SubPhase[] @relation("ResourceSubPhases")
  clicks    Click[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([primaryPhaseId])
  @@index([status])
  @@map("resources")
}

model Click {
  id         String   @id @default(cuid())
  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  referrer   String?
  ipHash     String?
  country    String?
  clickedAt  DateTime @default(now())

  @@index([resourceId])
  @@map("resource_clicks")
}
